            class="openModalBtn mt-auto group/btn flex w-full items-center justify-center gap-2 rounded-2xl border border-gray-200 px-8 py-3 text-lg font-semibold text-slate-800 transition-all duration-300 hover:-translate-y-1 hover:bg-black hover:text-white hover:shadow-xl"
            data-title="Mentor Islami"
            data-date="(Menyesuaikan)"
            data-sasaran="Mahasiswa Polinema"
            data-description="Program kerja untuk mengembangkan kreativitas mahasiswa dalam dakwah digital melalui fotografi dan videografi islami."
            data-image="https://placehold.co/1200x630"
            data-link="https://youtu.be/dQw4w9WgXcQ"
          >
            <span>Detail Kegiatan</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="w-5 h-5 transition-transform duration-300 group-hover/btn:translate-x-1"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
            </svg>
          </button>
        </div>
      </article>
    </div>
  </main>
  <!-- Modal -->
  <div
    id="modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4"
  >
    <div
      class="relative max-h-[90vh] w-full max-w-4xl overflow-y-auto rounded-3xl bg-white shadow-2xl"
    >
      <!-- tombol close atas -->
      <button
  id="closeModalBtn"
  class="absolute right-5 top-5 z-10 flex h-9 w-9 items-center justify-center rounded-full bg-white/90 text-2xl font-bold text-slate-700 shadow-lg transition hover:bg-red-500 hover:text-white"
>
  &times;
</button>

      <!-- Gambar -->
      <div class="relative h-[300px] overflow-hidden">
        <img id="modalImage" src="" class="h-full w-full object-cover" />

        <div class="absolute inset-0 bg-black/40"></div>

        <h2
          id="modalTitle"
          class="absolute bottom-6 left-6 text-4xl font-bold text-white"
        >
        </h2>
      </div>

      <!-- Isi -->
      <div class="p-8">
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl bg-yellow-50 p-5">
            <p class="text-sm text-orange-500">Tanggal</p>

            <h3 id="modalDate" class="mt-2 text-xl font-bold text-slate-800">
            </h3>
          </div>

          <div class="rounded-2xl bg-blue-50 p-5">
            <p class="text-sm text-blue-500">Sasaran</p>

            <h3 id="modalSasaran" class="mt-2 text-xl font-bold text-slate-800">
            </h3>
          </div>
        </div>

        <div class="mt-8">
          <h3 class="text-3xl font-bold text-slate-800">Deskripsi Kegiatan</h3>

          <p
            id="modalDescription"
            class="mt-4 text-lg leading-relaxed text-gray-600"
          >
          </p>
        </div>

        <div class="mt-10 flex gap-4">
          <button
            id="closeModalBtn2"
            class="w-full rounded-2xl bg-gray-200 py-4 font-bold"
          >
            Tutup
          </button>

          <a
            id="detailLink"
            href="#"
            class="flex w-full items-center justify-center rounded-2xl bg-primary-600 py-4 font-bold text-white"
          >
            Lihat Selengkapnya
          </a>
        </div>
      </div>
    </div>
  </div>
  <!-- VIDEO MODAL -->
  <div
    id="videoModal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-4"
  >
    <div class="relative w-full max-w-4xl">
      <button
        id="closeVideoBtn"
        class="absolute -top-12 right-0 text-4xl text-white"
      >
        x
      </button>

      <div class="aspect-video overflow-hidden rounded-2xl">
        <iframe
          id="videoFrame"
          class="h-full w-full"
          src=""
          title="Video"
          allowfullscreen></iframe>
      </div>
    </div>
  </div>
  <script>
    const modal = document.getElementById("modal")!;

    const openButtons = document.querySelectorAll(".openModalBtn");

    const closeBtn = document.getElementById("closeModalBtn")!;

    const closeBtn2 = document.getElementById("closeModalBtn2")!;

    // isi modal
    const modalTitle = document.getElementById("modalTitle")!;

    const modalDate = document.getElementById("modalDate")!;

    const modalSasaran = document.getElementById("modalSasaran")!;

    const modalDescription = document.getElementById("modalDescription")!;

    const modalImage = document.getElementById(
      "modalImage",
    ) as HTMLImageElement;

    const detailLink = document.getElementById(
      "detailLink",
    ) as HTMLAnchorElement;

    // buka modal
    openButtons.forEach((button) => {
      const btn = button as HTMLButtonElement;

      button.addEventListener("click", () => {
        const title = btn.dataset.title;

        const date = btn.dataset.date;

        const sasaran = btn.dataset.sasaran;

        const description = btn.dataset.description;

        const image = btn.dataset.image;

        const link = btn.dataset.link;

        // isi data modal
        modalTitle.textContent = title || "";

        modalDate.textContent = date || "";

        modalSasaran.textContent = sasaran || "";

        modalDescription.textContent = description || "";

        modalImage.src = image || "";

        detailLink.href = link || "#";

        // tampilkan modal
        modal.classList.remove("hidden");

        modal.classList.add("flex");
      });
    });

    // tombol close atas
    closeBtn.addEventListener("click", () => {
      modal.classList.add("hidden");

      modal.classList.remove("flex");
    });

    // tombol close bawah
    closeBtn2.addEventListener("click", () => {
      modal.classList.add("hidden");

      modal.classList.remove("flex");
    });

    // klik background untuk close
    modal.addEventListener("click", (e) => {
      if (e.target === modal) {
        modal.classList.add("hidden");

        modal.classList.remove("flex");
      }
    });

    // VIDEO MODAL
    const videoModal = document.getElementById("videoModal")!;

    const videoFrame = document.getElementById(
      "videoFrame",
    ) as HTMLIFrameElement;

    const closeVideoBtn = document.getElementById("closeVideoBtn")!;

    const videoButtons = document.querySelectorAll(".openVideoBtn");

    // buka video
    videoButtons.forEach((button) => {
      const btn = button as HTMLButtonElement;

      button.addEventListener("click", () => {
        const video = btn.dataset.video;

        videoFrame.src = video || "";

        videoModal.classList.remove("hidden");

        videoModal.classList.add("flex");
      });
    });

    // close video
    closeVideoBtn.addEventListener("click", () => {
      videoModal.classList.add("hidden");

      videoModal.classList.remove("flex");

      videoFrame.src = "";
    });
  </script>
</BaseLayout>

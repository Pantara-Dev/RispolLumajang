---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <main id="main-content">
    <section
      class="bg-gradient-to-b from-primary-600 to-primary-700 py-20 dark:from-primary-900 dark:to-gray-950"
    >
      <div class="container mx-auto px-4 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <span
            class="inline-flex items-center rounded-full bg-white/20 px-4 py-1.5 text-sm font-medium text-white"
          >
            Program Kerja
          </span>
          <h1
            class="mt-6 text-4xl font-bold tracking-tight text-white sm:text-5xl"
          >
            Program Kerja & Agenda
          </h1>
          <p class="mt-4 text-lg text-primary-100">
            Rispol menghadirkan berbagai Program Kerja yang berfokus pada
            Keagamaan, Pendidikan, Kebersihan, Rutinan, Penugasan untuk
            perubahan mahasiswa yang lebih baik.
          </p>
          <nav
            class="mt-6 flex items-center justify-center gap-2 text-sm text-primary-200"
            aria-label="Breadcrumb"
          >
            <a href="../index.html" class="transition-colors hover:text-white">
              Beranda
            </a>
            <span>/</span>
            <span class="text-white">Tentang Kami</span>
          </nav>
        </div>
      </div>
    </section>
    <section class="bg-gray-50 pt-6 pb-20 lg:pb-28 dark:bg-gray-950">
      <div class="mb-0 mx-auto max-w-xl">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          class="h-6 w-6 text-white"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
    </section>
    <div
      class="mb-10 flex flex-wrap items-center justify-center gap-2"
      data-blog-filters
    >
      <button
        type="button"
        data-filter="all"
        class="rounded-full bg-primary-600 px-4 py-2 text-sm font-medium text-white transition-colors dark:text-white"
      >
        Semua
      </button>
      <button
        type="button"
        data-filter="tips"
        class="rounded-full bg-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors dark:bg-gray-700 dark:text-gray-300"
      >
        Humas
      </button>
      <button
        type="button"
        data-filter="guide"
        class="rounded-full bg-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors dark:bg-gray-700 dark:text-gray-300"
      >
        Syiar
      </button>
      <button
        type="button"
        data-filter="lifestyle"
        class="rounded-full bg-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors dark:bg-gray-700 dark:text-gray-300"
      >
        Mentoring
      </button>
    </div>
    <div class="mx-auto grid max-w-7xl gap-8 sm:grid-cols-2 lg:grid-cols-3 px-4 sm:px-6 lg:px-8">
      <article
        data-category="tips"
        class="group flex flex-col h-full overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-200 transition-all hover:shadow-lg dark:bg-gray-900 dark:ring-gray-800"
      >
        <button
          class="openVideoBtn block aspect-[3/2] overflow-hidden shrink-0 w-full"
          data-video="https://www.youtube.com/embed/dQw4w9WgXcQ"
        >
          <img
            src="https://placehold.co/1200x630"
            alt="7 Organizing Tips for a Clutter-Free Home"
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
          />
        </button>

        <div class="flex flex-col flex-grow p-6">
          <div class="flex items-center gap-3">
            <span
              class="inline-flex items-center rounded-full bg-primary-100 px-2.5 py-0.5 text-xs font-medium text-primary-700 dark:bg-primary-900/50 dark:text-primary-300"
            >
              Humas
            </span>
            <span class="text-sm text-gray-500 dark:text-gray-400">
              (Menyesuaikan)
            </span>
          </div>

          <h3
            class="mt-3 text-lg font-bold text-gray-900 transition-colors group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400"
          >
            Lomba Fotografi dan Videografi Konten Islami
          </h3>

          <p
            class="mt-2 mb-6 line-clamp-2 text-sm text-gray-600 dark:text-gray-400"
          >
            Wadah Pengembangan bakat dan Implementasi ukhuwah islamiyah
          </p>

          <button
            class="openModalBtn mt-auto group/btn flex w-full items-center justify-center gap-2 rounded-2xl border border-gray-200 px-8 py-3 text-lg font-semibold text-slate-800 transition-all duration-300 hover:-translate-y-1 hover:bg-black hover:text-white hover:shadow-xl"
            data-title="Lomba Fotografi dan Videografi Konten Islami"
            data-date="(Menyesuaikan)"
            data-sasaran="SMA/SMK/MA Sederajat"
            data-description="Di tengah pesatnya perkembangan dunia digital, Lomba Fotografi dan Videografi Konten Islami hadir sebagai platform kreatif yang dirancang khusus bagi para mahasiswa. Ajang ini menjadi wadah strategis untuk mengembangkan bakat dan mengasah kreativitas visual mahasiswa dalam menghasilkan konten yang edukatif dan inspiratif."
            data-image="https://placehold.co/1200x630"
            data-link="https://youtu.be/dQw4w9WgXcQ"
          >
            <span>Detail Kegiatan</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="w-5 h-5 transition-transform duration-300 group-hover/btn:translate-x-1"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
            </svg>

---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <main id="main-content">
    <section
      class="bg-gradient-to-b from-primary-600 to-primary-700 py-20 dark:from-primary-900 dark:to-gray-950"
    >
      <div class="container mx-auto px-4 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <span
            class="inline-flex items-center rounded-full bg-white/20 px-4 py-1.5 text-sm font-medium text-white"
          >
            Program Kerja Rispol
          </span>
          <h1
            class="mt-6 text-4xl font-bold tracking-tight text-white sm:text-5xl"
          >
            Program Kerja & Agenda
          </h1>
          <p class="mt-4 text-lg text-primary-100">
            Rispol menghadirkan berbagai Program Kerja yang berfokus pada
            Keagamaan, Pendidikan, Kebersihan, Rutinan, Penugasan untuk perubahan
            mahasiswa yang lebih baik.
          </p>
          <nav
            class="mt-6 flex items-center justify-center gap-2 text-sm text-primary-200"
            aria-label="Breadcrumb"
          >
            <a href="../index.html" class="transition-colors hover:text-white">
              Beranda
            </a>
            <span>/</span>
            <span class="text-white">Blog</span>
          </nav>
        </div>
      </div>
    </section>
    <section class="bg-gray-50 py-20 lg:py-28 dark:bg-gray-950">
      <div class="container mx-auto px-4 lg:px-8">
        <div class="mb-8 mx-auto max-w-xl">
          <div class="relative">
            <svg
              class="absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-gray-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input
              type="text"
              data-blog-search
              placeholder="Cari Program Kerja..."
              class="w-full rounded-full border border-gray-200 bg-white py-3 pl-12 pr-4 text-gray-900 shadow-sm placeholder:text-gray-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 dark:border-gray-700 dark:bg-gray-900 dark:text-white dark:placeholder:text-gray-500"
            />
          </div>
        </div>
        <div
          class="mb-10 flex flex-wrap items-center justify-center gap-2"
          data-blog-filters
        >
          <button
            type="button"
            data-filter="all"
            class="rounded-full bg-primary-600 px-4 py-2 text-sm font-medium text-white transition-colors dark:text-white"
          >
            Semua
          </button>
          <button
            type="button"
            data-filter="tips"
            class="rounded-full bg-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors dark:bg-gray-700 dark:text-gray-300"
          >
            Humas
          </button>
          <button
            type="button"
            data-filter="guide"
            class="rounded-full bg-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors dark:bg-gray-700 dark:text-gray-300"
          >
            Syiar
          </button>
          <button
            type="button"
            data-filter="lifestyle"
            class="rounded-full bg-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors dark:bg-gray-700 dark:text-gray-300"
          >
            Mentoring
          </button>
        </div>
        <div class="mx-auto grid max-w-7xl gap-8 sm:grid-cols-2 lg:grid-cols-3">
          <article
            data-category="lifestyle"
            class="group flex flex-col h-full overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-200 transition-all hover:shadow-lg dark:bg-gray-900 dark:ring-gray-800"
          >
            <a
              href="organizing-tips-for-a-clutter-free-home/index.html"
              class="block aspect-[3/2] overflow-hidden shrink-0"
            >
              <img
                src="https://images.unsplash.com/photo-1527515545081-5db817172677?w=1200&h=630&fit=crop"
                alt="7 Organizing Tips for a Clutter-Free Home"
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
            </a>

            <div class="flex flex-col flex-grow p-6">
              <div class="flex items-center gap-3">
                <span
                  class="inline-flex items-center rounded-full bg-primary-100 px-2.5 py-0.5 text-xs font-medium text-primary-700 dark:bg-primary-900/50 dark:text-primary-300"
                >
                  Mentoring
                </span>
                <span class="text-sm text-gray-500 dark:text-gray-400">
                  November 22, 2025
                </span>
              </div>

              <h3
                class="mt-3 text-lg font-bold text-gray-900 transition-colors group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400"
              >
                7 Organizing Tips for a Clutter-Free Home

---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
<main id="main-content">
        <section class="bg-gradient-to-b from-primary-600 to-primary-700 py-20 dark:from-primary-900 dark:to-gray-950">
          <div class="container mx-auto px-4 lg:px-8">
            <div class="mx-auto max-w-3xl text-center">
              <span class="inline-flex items-center rounded-full bg-white/20 px-4 py-1.5 text-sm font-medium text-white">
                Our Blog
              </span>
              <h1 class="mt-6 text-4xl font-bold tracking-tight text-white sm:text-5xl">
                Cleaning Tips & Insights
              </h1>
              <p class="mt-4 text-lg text-primary-100">
                Stay up to date with the latest cleaning tips, home care guides,
                and industry insights from our team.
              </p>
              <nav
                class="mt-6 flex items-center justify-center gap-2 text-sm text-primary-200"
                aria-label="Breadcrumb"
              >
                <a
                  href="../index.html"
                  class="transition-colors hover:text-white"
                >
                  Home
                </a>
                <span>/</span> <span class="text-white">Blog</span>
              </nav>
            </div>
          </div>
        </section>
        <section class="bg-gray-50 py-20 lg:py-28 dark:bg-gray-950">
          <div class="container mx-auto px-4 lg:px-8">
            <div class="mb-8 mx-auto max-w-xl">
              <div class="relative">
                <svg
                  class="absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-gray-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                  ></path>
                </svg>
                <input
                  type="text"
                  data-blog-search
                  placeholder="Search articles..."
                  class="w-full rounded-full border border-gray-200 bg-white py-3 pl-12 pr-4 text-gray-900 shadow-sm placeholder:text-gray-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 dark:border-gray-700 dark:bg-gray-900 dark:text-white dark:placeholder:text-gray-500"
                />
              </div>
            </div>
            <div
              class="mb-10 flex flex-wrap items-center justify-center gap-2"
              data-blog-filters
            >
              <button
                type="button"
                data-filter="all"
                class="rounded-full bg-primary-600 px-4 py-2 text-sm font-medium text-white transition-colors dark:text-white"
              >
                All
              </button>
              <button
                type="button"
                data-filter="tips"
                class="rounded-full bg-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors dark:bg-gray-700 dark:text-gray-300"
              >
                Tips
              </button>
              <button
                type="button"
                data-filter="guide"
                class="rounded-full bg-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors dark:bg-gray-700 dark:text-gray-300"
              >
                Guide
              </button>
              <button
                type="button"
                data-filter="lifestyle"
                class="rounded-full bg-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors dark:bg-gray-700 dark:text-gray-300"
              >
                Lifestyle
              </button>
            </div>
            <div class="mx-auto grid max-w-7xl gap-8 sm:grid-cols-2 lg:grid-cols-3">
              <article
                data-category="tips"
                class="group overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-200 transition-all hover:shadow-lg dark:bg-gray-900 dark:ring-gray-800"
              >
                <a
                  href="benefits-of-professional-cleaning/index.html"
                  class="block"
                >
                  <div class="aspect-[3/2] overflow-hidden">
                    <img
                      src="https://images.unsplash.com/photo-1628177142898-93e36e4e3a50?w=800&amp;h=500&amp;fit=crop"
                      alt="5 Surprising Benefits of Professional Cleaning Services"
                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-6">
                    <div class="flex items-center gap-3">
                      <span class="inline-flex items-center rounded-full bg-primary-100 px-2.5 py-0.5 text-xs font-medium text-primary-700 dark:bg-primary-900/50 dark:text-primary-300">
                        Tips
                      </span>
                      <span class="text-sm text-gray-500 dark:text-gray-400">
                        February 18, 2026
                      </span>
                    </div>
                    <h3 class="mt-3 text-lg font-bold text-gray-900 transition-colors group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400">
                      5 Surprising Benefits of Professional Cleaning Services
                    </h3>
                    <p class="mt-2 line-clamp-2 text-sm text-gray-600 dark:text-gray-400">
                      Beyond a clean home, professional cleaning offers health
                      benefits, time savings, and even financial returns you
                      might not expect.
                    </p>
                    <div class="mt-4 flex items-center gap-3">
                      <img
                        src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100&amp;h=100&amp;fit=crop&amp;crop=face"
                        alt="Carlos Rivera"
                        class="h-8 w-8 rounded-full object-cover"
                      />
                      <div>
                        <div class="text-sm font-medium text-gray-900 dark:text-white">
                          Carlos Rivera
                        </div>
                        <div class="text-xs text-gray-500 dark:text-gray-400">
                          6 min read
                        </div>
                      </div>
                    </div>
                  </div>
                </a>
              </article>
              <article
                data-category="tips"
                class="group overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-200 transition-all hover:shadow-lg dark:bg-gray-900 dark:ring-gray-800"
              >
                <a href="eco-friendly-cleaning-tips/index.html" class="block">
                  <div class="aspect-[3/2] overflow-hidden">
                    <img
                      src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&amp;h=500&amp;fit=crop"
                      alt="10 Eco-Friendly Cleaning Tips That Actually Work"
                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-6">
                    <div class="flex items-center gap-3">
                      <span class="inline-flex items-center rounded-full bg-primary-100 px-2.5 py-0.5 text-xs font-medium text-primary-700 dark:bg-primary-900/50 dark:text-primary-300">
                        Tips
                      </span>
                      <span class="text-sm text-gray-500 dark:text-gray-400">
                        February 3, 2026
                      </span>
                    </div>
                    <h3 class="mt-3 text-lg font-bold text-gray-900 transition-colors group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400">
                      10 Eco-Friendly Cleaning Tips That Actually Work
                    </h3>
                    <p class="mt-2 line-clamp-2 text-sm text-gray-600 dark:text-gray-400">
                      Discover natural cleaning solutions using everyday
                      household items. Better for your health, your family, and
                      the environment.
                    </p>
                    <div class="mt-4 flex items-center gap-3">
                      <img
                        src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=100&amp;h=100&amp;fit=crop&amp;crop=face"
                        alt="Aisha Patel"
                        class="h-8 w-8 rounded-full object-cover"
                      />
                      <div>
                        <div class="text-sm font-medium text-gray-900 dark:text-white">
                          Aisha Patel
                        </div>
                        <div class="text-xs text-gray-500 dark:text-gray-400">
                          6 min read
                        </div>
                      </div>
                    </div>
                  </div>
                </a>
              </article>
              <article
                data-category="guide"
                class="group overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-200 transition-all hover:shadow-lg dark:bg-gray-900 dark:ring-gray-800"
              >
                <a href="cleaning-before-moving-guide/index.html" class="block">
                  <div class="aspect-[3/2] overflow-hidden">
                    <img
                      src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=1200&amp;h=630&amp;fit=crop"
                      alt="The Complete Guide to Cleaning Before Moving"
                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-6">
                    <div class="flex items-center gap-3">
                      <span class="inline-flex items-center rounded-full bg-primary-100 px-2.5 py-0.5 text-xs font-medium text-primary-700 dark:bg-primary-900/50 dark:text-primary-300">
                        Guide
                      </span>
                      <span class="text-sm text-gray-500 dark:text-gray-400">
                        January 28, 2026
                      </span>
                    </div>
                    <h3 class="mt-3 text-lg font-bold text-gray-900 transition-colors group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400">
                      The Complete Guide to Cleaning Before Moving
                    </h3>
                    <p class="mt-2 line-clamp-2 text-sm text-gray-600 dark:text-gray-400">
                      Whether moving in or out, this guide covers everything you
                      need to know about pre-move cleaning to protect your
                      deposit and start fresh.
                    </p>
                    <div class="mt-4 flex items-center gap-3">
                      <img
                        src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&amp;h=100&amp;fit=crop&amp;crop=face"
                        alt="James Cooper"
                        class="h-8 w-8 rounded-full object-cover"
                      />
                      <div>
                        <div class="text-sm font-medium text-gray-900 dark:text-white">
                          James Cooper
                        </div>
                        <div class="text-xs text-gray-500 dark:text-gray-400">
                          7 min read
                        </div>
                      </div>
                    </div>
                  </div>
                </a>
              </article>
              <article
                data-category="guide"
                class="group overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-200 transition-all hover:shadow-lg dark:bg-gray-900 dark:ring-gray-800"
              >
                <a href="spring-cleaning-checklist/index.html" class="block">
                  <div class="aspect-[3/2] overflow-hidden">
                    <img
                      src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800&amp;h=500&amp;fit=crop"
                      alt="The Ultimate Spring Cleaning Checklist for Every Room"
                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-6">
                    <div class="flex items-center gap-3">
                      <span class="inline-flex items-center rounded-full bg-primary-100 px-2.5 py-0.5 text-xs font-medium text-primary-700 dark:bg-primary-900/50 dark:text-primary-300">
                        Guide
                      </span>
                      <span class="text-sm text-gray-500 dark:text-gray-400">
                        January 15, 2026
                      </span>
                    </div>
                    <h3 class="mt-3 text-lg font-bold text-gray-900 transition-colors group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400">
                      The Ultimate Spring Cleaning Checklist for Every Room
                    </h3>
                    <p class="mt-2 line-clamp-2 text-sm text-gray-600 dark:text-gray-400">
                      A comprehensive room-by-room guide to deep cleaning your
                      home this spring. From kitchen to bathroom, we cover every
                      detail.
                    </p>
                    <div class="mt-4 flex items-center gap-3">
                      <img
                        src="https://images.unsplash.com/photo-1580489944761-15a19d654956?w=100&amp;h=100&amp;fit=crop&amp;crop=face"
                        alt="Maria Vasquez"
                        class="h-8 w-8 rounded-full object-cover"
                      />
                      <div>
                        <div class="text-sm font-medium text-gray-900 dark:text-white">
                          Maria Vasquez
                        </div>
                        <div class="text-xs text-gray-500 dark:text-gray-400">
                          8 min read
                        </div>
                      </div>
                    </div>
                  </div>
                </a>
              </article>
              <article
                data-category="guide"
                class="group overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-200 transition-all hover:shadow-lg dark:bg-gray-900 dark:ring-gray-800"
              >
                <a
                  href="how-often-should-you-deep-clean/index.html"
                  class="block"
                >
                  <div class="aspect-[3/2] overflow-hidden">
                    <img
                      src="https://images.unsplash.com/photo-1527515637462-cff94eecc1ac?w=800&amp;h=500&amp;fit=crop"
                      alt="How Often Should You Deep Clean Your Home?"
                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-6">
                    <div class="flex items-center gap-3">
                      <span class="inline-flex items-center rounded-full bg-primary-100 px-2.5 py-0.5 text-xs font-medium text-primary-700 dark:bg-primary-900/50 dark:text-primary-300">
                        Guide
                      </span>
                      <span class="text-sm text-gray-500 dark:text-gray-400">
                        December 10, 2025
                      </span>
                    </div>
                    <h3 class="mt-3 text-lg font-bold text-gray-900 transition-colors group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400">
                      How Often Should You Deep Clean Your Home?
                    </h3>
                    <p class="mt-2 line-clamp-2 text-sm text-gray-600 dark:text-gray-400">
                      A practical guide to deep cleaning frequency for every
                      room. Learn the ideal schedule based on your household
                      size and lifestyle.
                    </p>
                    <div class="mt-4 flex items-center gap-3">
                      <img
                        src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&amp;h=100&amp;fit=crop&amp;crop=face"
                        alt="James Cooper"
                        class="h-8 w-8 rounded-full object-cover"
                      />
                      <div>
                        <div class="text-sm font-medium text-gray-900 dark:text-white">
                          James Cooper
                        </div>
                        <div class="text-xs text-gray-500 dark:text-gray-400">
                          7 min read
                        </div>
                      </div>
                    </div>
                  </div>
                </a>
              </article>
              <article
                data-category="lifestyle"
                class="group overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-200 transition-all hover:shadow-lg dark:bg-gray-900 dark:ring-gray-800"
              >
                <a
                  href="organizing-tips-for-a-clutter-free-home/index.html"
                  class="block"
                >
                  <div class="aspect-[3/2] overflow-hidden">
                    <img
                      src="https://images.unsplash.com/photo-1527515545081-5db817172677?w=1200&amp;h=630&amp;fit=crop"
                      alt="7 Organizing Tips for a Clutter-Free Home"
                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-6">
                    <div class="flex items-center gap-3">
                      <span class="inline-flex items-center rounded-full bg-primary-100 px-2.5 py-0.5 text-xs font-medium text-primary-700 dark:bg-primary-900/50 dark:text-primary-300">
                        Lifestyle
                      </span>
                      <span class="text-sm text-gray-500 dark:text-gray-400">
                        November 22, 2025
                      </span>
                    </div>
                    <h3 class="mt-3 text-lg font-bold text-gray-900 transition-colors group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400">
                      7 Organizing Tips for a Clutter-Free Home
                    </h3>
                    <p class="mt-2 line-clamp-2 text-sm text-gray-600 dark:text-gray-400">
                      Simple decluttering strategies that professional
                      organizers swear by. Transform your space with these
                      practical methods.
                    </p>
                    <div class="mt-4 flex items-center gap-3">
                      <img
                        src="https://images.unsplash.com/photo-1580489944761-15a19d654956?w=100&amp;h=100&amp;fit=crop&amp;crop=face"
                        alt="Maria Vasquez"
                        class="h-8 w-8 rounded-full object-cover"
                      />
                      <div>
                        <div class="text-sm font-medium text-gray-900 dark:text-white">
                          Maria Vasquez
                        </div>
                        <div class="text-xs text-gray-500 dark:text-gray-400">
                          5 min read
                        </div>
                      </div>
                    </div>
                  </div>
                </a>
              </article>
            </div>
          </div>
        </section>
        <section class="bg-gray-50 py-20 lg:py-28 dark:bg-gray-950">
          <div class="container mx-auto px-4 lg:px-8">
            <div class="mx-auto max-w-3xl rounded-2xl bg-gray-900 px-8 py-16 text-center shadow-xl dark:bg-gray-800">
              <span class="inline-flex items-center rounded-full bg-primary-600/20 px-4 py-1.5 text-sm font-medium text-primary-400">
                Newsletter
              </span>
              <h2 class="mt-4 text-3xl font-bold text-white sm:text-4xl">
                Stay in the Loop
              </h2>
              <p class="mt-4 text-lg text-gray-400">
                Subscribe to our newsletter for the latest cleaning tips,
                seasonal checklists, and exclusive offers.
              </p>
              <form class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
                <input
                  type="email"
                  placeholder="Enter your email"
                  class="w-full max-w-sm rounded-full border border-gray-700 bg-gray-800 px-6 py-3 text-white shadow-lg placeholder:text-gray-500 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 sm:w-auto"
                />
                <button
                  type="submit"
                  class="w-full rounded-full bg-primary-600 px-8 py-3 font-semibold text-white shadow-lg transition-all hover:bg-primary-700 sm:w-auto"
                >
                  Subscribe
                </button>
              </form>
            </div>
          </div>
        </section>
      </main>
</BaseLayout>
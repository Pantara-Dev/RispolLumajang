---
import BaseLayout from "../layouts/BaseLayout.astro"
---

<BaseLayout>
    <main id="main-content">
        <section class="bg-primary-600 py-16 lg:py-24 dark:bg-primary-900">
          <div class="container mx-auto px-4 text-center lg:px-8">
            <h1 class="text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
              About SparkleClean
            </h1>
            <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-100">
              Austin&#39;s trusted cleaning professionals since 2018. Insured,
              bonded, and eco-friendly.
            </p>
            <nav
              class="mt-6 flex items-center justify-center gap-2 text-sm text-primary-200"
              aria-label="Breadcrumb"
            >
              <a
                href="../index.html"
                class="transition-colors hover:text-white"
              >
                Home
              </a>
              <span>/</span> <span class="text-white">About</span>
            </nav>
          </div>
        </section>
        <section class="py-20 lg:py-28">
          <div class="container mx-auto px-4 lg:px-8">
            <div class="grid items-center gap-12 lg:grid-cols-2">
              <div>
                <div class="mb-4 inline-flex items-center rounded-full bg-primary-100 px-3 py-1 text-sm font-medium text-primary-700 dark:bg-primary-900/50 dark:text-primary-300">
                  Our Story
                </div>
                <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl dark:text-white">
                  Cleaning with Heart
                </h2>
                <p class="mt-4 text-lg font-medium italic text-primary-600 dark:text-primary-400">
                  &ldquo;To deliver exceptional cleaning services that give
                  people back their time, using safe products and reliable teams
                  who treat every home like their own.&rdquo;
                </p>
                <p class="mt-4 text-gray-600 dark:text-gray-400">
                  SparkleClean was founded in 2018 by Maria Vasquez, a lifelong
                  Austin resident who saw a gap in the market for truly
                  reliable, eco-conscious cleaning services. What started as a
                  one-woman operation has grown into a team of 40+ trained
                  cleaning professionals serving the greater Austin area.
                </p>
                <p class="mt-4 text-gray-600 dark:text-gray-400">
                  We believe a clean home should not come at the cost of your
                  health or the environment. That is why every product we use is
                  EPA-certified, cruelty-free, and safe for families with
                  children and pets. Our rigorous hiring process includes
                  background checks, skills training, and ongoing quality
                  assurance.
                </p>
              </div>
              <div class="overflow-hidden rounded-2xl">
                <img
                  src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800&amp;h=600&amp;fit=crop"
                  alt="About SparkleClean"
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>
            </div>
          </div>
        </section>
        <section class="bg-gray-50 py-20 lg:py-28 dark:bg-gray-900">
          <div class="container mx-auto px-4 lg:px-8">
            <div class="mx-auto max-w-3xl text-center">
              <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl dark:text-white">
                Our Core Values
              </h2>
              <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
                The principles that drive every clean we do.
              </p>
            </div>
            <div class="mt-16 grid gap-8 sm:grid-cols-3">
              <div class="rounded-2xl bg-white p-8 shadow-sm dark:bg-gray-800">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary-100 text-primary-600 dark:bg-primary-900/50 dark:text-primary-400">
                  <svg
                    class="h-6 w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"
                    ></path>
                  </svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                  Customer First
                </h3>
                <p class="mt-2 text-gray-600 dark:text-gray-400">
                  Your satisfaction is our top priority. If you are not happy
                  with any part of our service, we will re-clean it for free
                  within 24 hours.
                </p>
              </div>
              <div class="rounded-2xl bg-white p-8 shadow-sm dark:bg-gray-800">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary-100 text-primary-600 dark:bg-primary-900/50 dark:text-primary-400">
                  <svg
                    class="h-6 w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"
                    ></path>
                  </svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                  Eco-Friendly
                </h3>
                <p class="mt-2 text-gray-600 dark:text-gray-400">
                  We use only EPA-certified, green cleaning products that are
                  safe for children, pets, and the environment without
                  sacrificing results.
                </p>
              </div>
              <div class="rounded-2xl bg-white p-8 shadow-sm dark:bg-gray-800">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary-100 text-primary-600 dark:bg-primary-900/50 dark:text-primary-400">
                  <svg
                    class="h-6 w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"
                    ></path>
                  </svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                  Reliability
                </h3>
                <p class="mt-2 text-gray-600 dark:text-gray-400">
                  We show up on time, every time. Our teams are
                  background-checked, insured, and trained to deliver consistent
                  quality.
                </p>
              </div>
            </div>
          </div>
        </section>
        <section class="py-20 lg:py-28">
          <div class="container mx-auto px-4 lg:px-8">
            <div class="mx-auto max-w-3xl text-center">
              <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl dark:text-white">
                Meet Our Team
              </h2>
              <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
                The people behind the sparkle.
              </p>
            </div>
            <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
              <div class="text-center">
                <div class="mx-auto h-40 w-40 overflow-hidden rounded-full">
                  <img
                    src="https://images.unsplash.com/photo-1580489944761-15a19d654956?w=300&amp;h=300&amp;fit=crop&amp;crop=face"
                    alt="Maria Vasquez"
                    class="h-full w-full object-cover"
                    loading="lazy"
                  />
                </div>
                <h3 class="mt-4 text-lg font-semibold text-gray-900 dark:text-white">
                  Maria Vasquez
                </h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">
                  Founder &amp; CEO
                </p>
              </div>
              <div class="text-center">
                <div class="mx-auto h-40 w-40 overflow-hidden rounded-full">
                  <img
                    src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=300&amp;h=300&amp;fit=crop&amp;crop=face"
                    alt="James Cooper"
                    class="h-full w-full object-cover"
                    loading="lazy"
                  />
                </div>
                <h3 class="mt-4 text-lg font-semibold text-gray-900 dark:text-white">
                  James Cooper
                </h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">
                  Operations Manager
                </p>
              </div>
              <div class="text-center">
                <div class="mx-auto h-40 w-40 overflow-hidden rounded-full">
                  <img
                    src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=300&amp;h=300&amp;fit=crop&amp;crop=face"
                    alt="Aisha Patel"
                    class="h-full w-full object-cover"
                    loading="lazy"
                  />
                </div>
                <h3 class="mt-4 text-lg font-semibold text-gray-900 dark:text-white">
                  Aisha Patel
                </h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">
                  Quality Assurance Lead
                </p>
              </div>
              <div class="text-center">
                <div class="mx-auto h-40 w-40 overflow-hidden rounded-full">
                  <img
                    src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=300&amp;h=300&amp;fit=crop&amp;crop=face"
                    alt="Carlos Rivera"
                    class="h-full w-full object-cover"
                    loading="lazy"
                  />
                </div>
                <h3 class="mt-4 text-lg font-semibold text-gray-900 dark:text-white">
                  Carlos Rivera
                </h3>
                <p class="text-sm text-gray-600 dark:text-gray-400">
                  Commercial Division Head
                </p>
              </div>
            </div>
          </div>
        </section>
        <section class="bg-primary-600 py-16 lg:py-24 dark:bg-primary-900">
          <div class="container mx-auto px-4 text-center lg:px-8">
            <h2 class="text-3xl font-bold text-white sm:text-4xl">
              Ready for a Cleaner Home?
            </h2>
            <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-100">
              Experience the SparkleClean difference. Book your first cleaning
              today.
            </p>
            <a
              href="../index.html#quote"
              class="mt-8 inline-flex items-center justify-center rounded-lg bg-white px-6 py-3 text-sm font-medium text-primary-600 shadow-lg transition-all hover:bg-gray-100"
            >
              Get Free Quote
            </a>
          </div>
        </section>
      </main>
</BaseLayout>
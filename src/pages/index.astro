---
import BaseLayout from "../layouts/BaseLayout.astro";


---

<!doctype html>
<BaseLayout>
   <main id="main-content">
      <section
        id="quote"
        class="relative overflow-hidden bg-gradient-to-b from-primary-50 to-white dark:from-gray-900 dark:to-gray-950"
      >
        <div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
          <div
            class="animate-hero-float absolute -top-40 left-1/2 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-primary-200/50 blur-3xl dark:bg-primary-900/30"
            data-parallax="0.15"
          ></div>
          <div
            class="animate-hero-float-reverse absolute right-0 top-0 h-[400px] w-[400px] rounded-full bg-accent-200/30 blur-3xl dark:bg-accent-900/20"
            data-parallax="-0.1"
          ></div>
        </div>
        <div class="container mx-auto px-4 py-20 lg:px-8 lg:py-28">
          <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
            <!-- Left Side: Content -->
            <div>
              <div
                class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary-200 bg-primary-50 px-4 py-1.5 text-sm font-medium text-primary-700 dark:border-primary-800 dark:bg-primary-900/50 dark:text-primary-300"
                data-animate="fade-in-up"
              >
                <span class="relative flex h-2 w-2">
                  <span
                    class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary-400 opacity-75"
                  ></span>
                  <span
                    class="relative inline-flex h-2 w-2 rounded-full bg-primary-500"
                  ></span>
                </span>
                Instant Quote
              </div>
              <h1
                class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl dark:text-white"
                data-animate="fade-in-up"
                data-delay="100"
              >
                Professional Cleaning, <br />
                <span
                  class="text-gradient"
                  data-typewriter="[&#34;Made Simple&#34;,&#34;Eco-Friendly&#34;,&#34;You Can Trust&#34;]"
                  >Guaranteed Spotless</span
                >
              </h1>
              <p
                class="mt-6 max-w-xl text-lg text-gray-600 dark:text-gray-400"
                data-animate="fade-in-up"
                data-delay="200"
              >
                Trusted by thousands of homeowners and businesses in Austin. Our
                insured, background-checked cleaning professionals use
                eco-friendly products to deliver a spotless space every single
                time.
              </p>
              <div
                class="mt-8 flex flex-col items-start gap-4 sm:flex-row"
                data-animate="fade-in-up"
                data-delay="300"
              >
                <a
                  href="#quote"
                  class="inline-flex items-center justify-center gap-2 rounded-lg bg-primary-600 px-6 py-3 text-base font-medium text-white shadow-lg shadow-primary-600/25 transition-all hover:bg-primary-700 hover:shadow-xl hover:shadow-primary-600/30"
                >
                  Get Free Quote
                  <svg
                    class="h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"
                    ></path>
                  </svg>
                </a>
                <a
                  href="tel:5558675309"
                  class="inline-flex items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-6 py-3 text-base font-medium text-gray-700 transition-colors hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-300 dark:hover:bg-gray-800"
                >
                  <svg
                    class="h-5 w-5 text-primary-600"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                    ></path>
                  </svg>
                  Call (555) 867-5309
                </a>
              </div>
              <div
                class="mt-12 grid grid-cols-2 gap-6 sm:grid-cols-4"
                data-animate="fade-in-up"
                data-delay="400"
              >
                <div class="text-center sm:text-left">
                  <div class="text-2xl font-bold text-gray-900 dark:text-white">
                    5000+
                  </div>
                  <div class="mt-0.5 text-sm text-gray-600 dark:text-gray-400">
                    Homes Cleaned
                  </div>
                </div>
                <div class="text-center sm:text-left">
                  <div class="text-2xl font-bold text-gray-900 dark:text-white">
                    4.9★
                  </div>
                  <div class="mt-0.5 text-sm text-gray-600 dark:text-gray-400">
                    Star Rating
                  </div>
                </div>
                <div class="text-center sm:text-left">
                  <div class="text-2xl font-bold text-gray-900 dark:text-white">
                    100%
                  </div>
                  <div class="mt-0.5 text-sm text-gray-600 dark:text-gray-400">
                    Satisfaction
                  </div>
                </div>
                <div class="text-center sm:text-left">
                  <div class="text-2xl font-bold text-gray-900 dark:text-white">
                    200+
                  </div>
                  <div class="mt-0.5 text-sm text-gray-600 dark:text-gray-400">
                    5-Star Reviews
                  </div>
                </div>
              </div>
            </div>
            <!-- Right Side: Quote Calculator -->
            <div
              class="rounded-2xl border border-gray-200 bg-white p-6 shadow-xl sm:p-8 dark:border-gray-800 dark:bg-gray-900"
              data-quote-calculator
              data-animate="fade-in-up"
              data-delay="200"
            >
              <h2 class="text-xl font-bold text-gray-900 dark:text-white">
                Instant Quote
              </h2>
              <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                Get your estimated price in seconds
              </p>
              <div class="mt-6 space-y-5">
                <div>
                  <label
                    class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-300"
                    >Property Type</label
                  >
                  <select
                    data-quote-property
                    class="w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-gray-900 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                  >
                    <option value="house">House</option>
                    <option value="apartment">Apartment</option>
                    <option value="condo">Condo</option>
                    <option value="office">Office</option>
                  </select>
                </div>
                <div>
                  <div class="mb-1.5 flex items-center justify-between">
                    <label
                      class="text-sm font-medium text-gray-700 dark:text-gray-300"
                      >Home Size</label
                    >
                    <span
                      class="text-sm font-semibold text-primary-600 dark:text-primary-400"
                      data-quote-size-value
                      >1500 sq ft</span
                    >
                  </div>
                  <input
                    type="range"
                    min="500"
                    max="5000"
                    step="100"
                    value="1500"
                    data-quote-size
                    data-range-slider
                    class="w-full"
                  />
                  <div class="mt-1 flex justify-between text-xs text-gray-400">
                    <span>500 sq ft</span> <span>5000 sq ft</span>
                  </div>
                </div>
                <div>
                  <label
                    class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-300"
                    >Bedrooms</label
                  >
                  <div class="flex items-center gap-4">
                    <button
                      type="button"
                      data-quote-rooms-minus
                      class="flex h-10 w-10 items-center justify-center rounded-lg border border-gray-300 text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-800"
                    >
                      <svg
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M20 12H4"
                        ></path>
                      </svg>
                    </button>
                    <span
                      class="w-8 text-center text-lg font-bold text-gray-900 dark:text-white"
                      data-quote-rooms-value
                      >3</span
                    >
                    <button
                      type="button"
                      data-quote-rooms-plus
                      class="flex h-10 w-10 items-center justify-center rounded-lg border border-gray-300 text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-800"
                    >
                      <svg
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M12 4v16m8-8H4"
                        ></path>
                      </svg>
                    </button>
                  </div>
                </div>
                <div>
                  <label
                    class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-300"
                    >Frequency</label
                  >
                  <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">
                    <button
                      type="button"
                      data-quote-frequency="once"
                      class="rounded-lg px-3 py-2 text-sm font-medium transition-colors bg-primary-600 text-white"
                    >
                      One-Time</button
                    ><button
                      type="button"
                      data-quote-frequency="weekly"
                      class="rounded-lg px-3 py-2 text-sm font-medium transition-colors bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300"
                    >
                      Weekly</button
                    ><button
                      type="button"
                      data-quote-frequency="biweekly"
                      class="rounded-lg px-3 py-2 text-sm font-medium transition-colors bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300"
                    >
                      Bi-Weekly</button
                    ><button
                      type="button"
                      data-quote-frequency="monthly"
                      class="rounded-lg px-3 py-2 text-sm font-medium transition-colors bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300"
                    >
                      Monthly
                    </button>
                  </div>
                </div>
              </div>
              <div
                class="mt-6 rounded-xl bg-primary-50 p-5 text-center dark:bg-primary-900/30"
              >
                <div
                  class="text-sm font-medium text-primary-700 dark:text-primary-300"
                >
                  Estimated Price
                </div>
                <div
                  class="mt-1 text-5xl font-bold text-primary-600 dark:text-primary-400"
                  data-quote-price
                >
                  $315
                </div>
                <div
                  class="mt-1 text-sm font-medium text-accent-600 dark:text-accent-400"
                  data-quote-discount
                  style="display: none"
                ></div>
              </div>
              <a
                href="contact/index.html"
                class="mt-5 block w-full rounded-lg bg-primary-600 py-3 text-center text-sm font-semibold text-white shadow-lg shadow-primary-600/25 transition-all hover:bg-primary-700 hover:shadow-xl hover:shadow-primary-600/30"
              >
                Book Now
              </a>
            </div>
          </div>
        </div>
      </section>
      <div class="relative -mt-1 text-gray-50 dark:text-gray-900">
        <svg
          viewBox="0 0 1440 80"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="w-full"
          preserveAspectRatio="none"
        >
          <path
            d="M0 40C240 80 480 0 720 40C960 80 1200 0 1440 40V80H0V40Z"
            fill="currentColor"
          ></path>
        </svg>
      </div>
      <section
        class="border-y border-gray-200 bg-white py-12 dark:border-gray-800 dark:bg-gray-950"
      >
        <div class="container mx-auto px-4 lg:px-8">
          <div class="grid grid-cols-2 gap-8 lg:grid-cols-4">
            <div
              class="flex flex-col items-center text-center"
              data-animate="fade-in-up"
              data-delay="0"
            >
              <div
                class="flex h-14 w-14 items-center justify-center rounded-full bg-primary-100 text-primary-600 dark:bg-primary-900/50 dark:text-primary-400"
              >
                <svg
                  class="h-7 w-7"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                  />
                </svg>
              </div>
              <h3
                class="mt-3 text-sm font-semibold text-gray-900 dark:text-white"
              >
                Fully Insured
              </h3>
              <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">
                Up to $2M liability coverage for complete peace of mind.
              </p>
            </div>
            <div
              class="flex flex-col items-center text-center"
              data-animate="fade-in-up"
              data-delay="100"
            >
              <div
                class="flex h-14 w-14 items-center justify-center rounded-full bg-primary-100 text-primary-600 dark:bg-primary-900/50 dark:text-primary-400"
              >
                <svg
                  class="h-7 w-7"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
              </div>
              <h3
                class="mt-3 text-sm font-semibold text-gray-900 dark:text-white"
              >
                Background Checked
              </h3>
              <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">
                Every team member passes thorough background screening.
              </p>
            </div>
            <div
              class="flex flex-col items-center text-center"
              data-animate="fade-in-up"
              data-delay="200"
            >
              <div
                class="flex h-14 w-14 items-center justify-center rounded-full bg-primary-100 text-primary-600 dark:bg-primary-900/50 dark:text-primary-400"
              >
                <svg
                  class="h-7 w-7"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
                  />
                </svg>
              </div>
              <h3
                class="mt-3 text-sm font-semibold text-gray-900 dark:text-white"
              >
                Eco-Friendly
              </h3>
              <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">
                Green-certified products safe for kids, pets, and the planet.
              </p>
            </div>
            <div
              class="flex flex-col items-center text-center"
              data-animate="fade-in-up"
              data-delay="300"
            >
              <div
                class="flex h-14 w-14 items-center justify-center rounded-full bg-primary-100 text-primary-600 dark:bg-primary-900/50 dark:text-primary-400"
              >
                <svg
                  class="h-7 w-7"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                  />
                </svg>
              </div>
              <h3
                class="mt-3 text-sm font-semibold text-gray-900 dark:text-white"
              >
                Satisfaction Guaranteed
              </h3>
              <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">
                Not happy? We&#39;ll re-clean for free within 24 hours.
              </p>
            </div>
          </div>
        </div>
      </section>
      <section
        class="border-y border-gray-200 bg-gray-50 py-16 lg:py-20 dark:border-gray-800 dark:bg-gray-900"
      >
        <div class="container mx-auto px-4 lg:px-8">
          <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">
            <div class="text-center" data-animate="fade-in-up" data-delay="0">
              <div
                class="text-4xl font-bold text-primary-600 lg:text-5xl dark:text-primary-400"
              >
                <span data-counter="5000+">0</span>
              </div>
              <div
                class="mt-2 text-sm font-medium text-gray-600 dark:text-gray-400"
              >
                Homes Cleaned
              </div>
            </div>
            <div class="text-center" data-animate="fade-in-up" data-delay="100">
              <div
                class="text-4xl font-bold text-primary-600 lg:text-5xl dark:text-primary-400"
              >
                <span data-counter="200+">0</span>
              </div>
              <div
                class="mt-2 text-sm font-medium text-gray-600 dark:text-gray-400"
              >
                Five-Star Reviews
              </div>
            </div>
            <div class="text-center" data-animate="fade-in-up" data-delay="200">
              <div
                class="text-4xl font-bold text-primary-600 lg:text-5xl dark:text-primary-400"
              >
                <span data-counter="8+">0</span>
              </div>
              <div
                class="mt-2 text-sm font-medium text-gray-600 dark:text-gray-400"
              >
                Years Experience
              </div>
            </div>
            <div class="text-center" data-animate="fade-in-up" data-delay="300">
              <div
                class="text-4xl font-bold text-primary-600 lg:text-5xl dark:text-primary-400"
              >
                <span data-counter="100%">0</span>
              </div>
              <div
                class="mt-2 text-sm font-medium text-gray-600 dark:text-gray-400"
              >
                Satisfaction Rate
              </div>
            </div>
          </div>
        </div>
      </section>
      <section id="services" class="bg-gray-50 py-20 lg:py-28 dark:bg-gray-900">
        <div class="container mx-auto px-4 lg:px-8">
          <div class="mx-auto max-w-3xl text-center">
            <div
              class="mb-4 inline-flex items-center rounded-full bg-primary-100 px-3 py-1 text-sm font-medium text-primary-700 dark:bg-primary-900/50 dark:text-primary-300"
              data-animate="fade-in-up"
            >
              Our Services
            </div>
            <h2
              class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl dark:text-white"
              data-animate="fade-in-up"
              data-delay="100"
            >
              Cleaning Services for Every Need
            </h2>
            <p
              class="mt-4 text-lg text-gray-600 dark:text-gray-400"
              data-animate="fade-in-up"
              data-delay="200"
            >
              From weekly home cleanings to large-scale commercial projects, we
              have the team and expertise to handle it all.
            </p>
          </div>
          <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            <div
              class="group relative rounded-2xl bg-white p-8 shadow-sm transition-all hover:shadow-lg dark:bg-gray-800"
              data-animate="fade-in-up"
              data-delay="100"
            >
              <div
                class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl bg-primary-100 text-primary-600 transition-colors group-hover:bg-primary-600 group-hover:text-white dark:bg-primary-900/50 dark:text-primary-400"
              >
                <svg
                  class="h-7 w-7"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
                  />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
                Regular Cleaning
              </h3>
              <p class="mt-3 text-gray-600 dark:text-gray-400">
                Weekly, bi-weekly, or monthly visits to keep your home
                consistently fresh, tidy, and welcoming for your family.
              </p>
            </div>
            <div
              class="group relative rounded-2xl bg-white p-8 shadow-sm transition-all hover:shadow-lg dark:bg-gray-800"
              data-animate="fade-in-up"
              data-delay="150"
            >
              <div
                class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl bg-primary-100 text-primary-600 transition-colors group-hover:bg-primary-600 group-hover:text-white dark:bg-primary-900/50 dark:text-primary-400"
              >
                <svg
                  class="h-7 w-7"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                  />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
                Deep Cleaning
              </h3>
              <p class="mt-3 text-gray-600 dark:text-gray-400">
                An intensive top-to-bottom clean that reaches every corner,
                baseboard, and hidden surface for a like-new feeling.
              </p>
            </div>
            <div
              class="group relative rounded-2xl bg-white p-8 shadow-sm transition-all hover:shadow-lg dark:bg-gray-800"
              data-animate="fade-in-up"
              data-delay="200"
            >
              <div
                class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl bg-primary-100 text-primary-600 transition-colors group-hover:bg-primary-600 group-hover:text-white dark:bg-primary-900/50 dark:text-primary-400"
              >
                <svg
                  class="h-7 w-7"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                  />

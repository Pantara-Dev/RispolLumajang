---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
<main id="main-content">
        <section class="bg-primary-600 py-16 lg:py-24 dark:bg-primary-900">
          <div class="container mx-auto px-4 text-center lg:px-8">
            <h1 class="text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
              Hubungi kami
            </h1>
            <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-100">
              Silakan hubungi kami melalui saluran resmi di bawah ini untuk pertanyaan, kerja sama, atau informasi lebih lanjut mengenai organisasi kami
            </p>
            <nav
              class="mt-6 flex items-center justify-center gap-2 text-sm text-primary-200"
              aria-label="Breadcrumb"
            >
              <a
                href="../index.html"
                class="transition-colors hover:text-white"
              >
                Home
              </a>
              <span>/</span> <span class="text-white">Kontak</span>
            </nav>
          </div>
        </section>
        <section class="py-20 lg:py-28">
          <div class="container mx-auto px-4 lg:px-8">
            <div class="grid gap-12 lg:grid-cols-5">
              <div class="lg:col-span-3">
                <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
                  Kirim pesan kepada Kami
                </h2>
                <p class="mt-2 text-gray-600 dark:text-gray-400">
                  Isilah formulir di bawah ini dan tim kami akan segera merespons.                
                </p>
                <form class="mt-8 space-y-6" data-validate data-contact-form>
                  <div class="grid gap-6 sm:grid-cols-2">
                    <div>
                      <label
                        for="Nama"
                        class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                      >
                        Nama Lengkap
                      </label>
                      <input
                        type="text"
                        id="Nama"
                        name="Nama"
                        required
                        class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-900 transition-colors focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                        placeholder="nama anda"
                      />
                    </div>
                    <div>
                      <label
                        for="email"
                        class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                      >
                        Email
                      </label>
                      <input
                        type="email"
                        id="email"
                        name="email"
                        required
                        class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-900 transition-colors focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                        placeholder="namagmailanda@gmail.com"
                      />
                    </div>
                  </div>
                  <div>
                    <label
                      for=""
                      class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                    >
                      subjek
                    </label>
                    <input
                      type="text"
                      id="subjek"
                      name="subjek"
                      class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-900 transition-colors focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                      placeholder="kajian islami, mentooring, pertnyaan lainnya...."
                    />
                  </div>
                  <div>
                    <label
                      for="Pesan"
                      class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                    >
                      Pesan
                    </label>
                    <textarea
                      id="pesan"
                      name="pesan"
                      rows="5"
                      required
                      class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-900 transition-colors focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-gray-700 dark:bg-gray-800 dark:text-white"
                      placeholder="Apa saja tantagan yang dialami oleh rispol"
                    ></textarea>
                  </div>
                  <button
                    type="Kirim"
                    class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-6 py-3 text-sm font-medium text-white shadow-lg shadow-primary-600/25 transition-all hover:bg-primary-700 hover:shadow-xl hover:shadow-primary-600/30"
                  >
                    Kirim Pesan
                    <svg
                      class="ml-2 h-5 w-5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                      ></path>
                    </svg>
                  </button>
                </form>
              </div>

              <div class="lg:col-span-2">
                <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
                  Menghubungi
                </h2>
                <p class="mt-2 text-gray-600 dark:text-gray-400">
                  Apakah kalian ingin bekerja sama dengan aku
                </p>
                <div class="mt-8 space-y-6">
                  <div class="flex items-start gap-4">
                    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary-100 text-primary-600 dark:bg-primary-900/50 dark:text-primary-400">
                      <svg
                        class="h-5 w-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                        ></path>
                      </svg>
                    </div>
                    <div>
                      <h3 class="font-semibold text-gray-900 dark:text-white">
                        Email
                      </h3>
                      <a
                        href="mailto:rispolukm@gmail.com"
                        class="text-gray-600 transition-colors hover:text-primary-600 dark:text-gray-400 dark:hover:text-primary-400"
                      >
                        rispolukm@gmail.com
                      </a>
                    </div>
                  </div>
                  <div class="flex items-start gap-4">
                    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary-100 text-primary-600 dark:bg-primary-900/50 dark:text-primary-400">
                      <svg
                        class="h-5 w-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                        ></path>
                      </svg>
                    </div>
                    <div>
                      <h3 class="font-semibold text-gray-900 dark:text-white">
                        Telepon
                      </h3>
                      <a
                        href="tel:+62 81459101209"
                        class="text-gray-600 transition-colors hover:text-primary-600 dark:text-gray-400 dark:hover:text-primary-400"
                      >
                        +62 81459101209
                      </a>
                    </div>
                  </div>
                  <div class="flex items-start gap-4">
                    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary-100 text-primary-600 dark:bg-primary-900/50 dark:text-primary-400">
                      <svg
                        class="h-5 w-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                        ></path>
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                        ></path>
                      </svg>
                    </div>
                    <div>
                      <h3 class="font-semibold text-gray-900 dark:text-white">
                        Alamat
                      </h3>
                      <p class="text-gray-600 dark:text-gray-400">
                        JLT, Lumajang, Jawa Timur, 67314
                      </p>
                    </div>
                  </div>
                  <div class="flex items-start gap-4">
                    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-primary-100 text-primary-600 dark:bg-primary-900/50 dark:text-primary-400">
                      <svg
                        class="h-5 w-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                        ></path>
                      </svg>
                    </div>
                    <div>
                      <h3 class="font-semibold text-gray-900 dark:text-white">
                        Jam Kerja
                      </h3>
                      <p class="text-gray-600 dark:text-gray-400">
                        Senin - Jum'at: 7:00 pagi - 00.00 malam
                      </p>
                      <p class="text-gray-600 dark:text-gray-400">
                        Sabtu: 9:00 pagi - 16:00 sore
                      </p>
                      <p class="text-gray-600 dark:text-gray-400">
                        Minggu: 10:00 pagi - 16:00 sore
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
        <section class="border-t border-gray-200 dark:border-gray-800">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3949.6240478163872!2d113.24019817405572!3d-8.139700581503687!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd667609cb4bd39%3A0xa38484bf8f293e32!2sPolinema%20Kampus%20Lumajang!5e0!3m2!1sid!2sid!4v1779506198299!5m2!1sid!2sid" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            class="h-80 w-full border-0"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Our location in Lumajang, Jawa Timur, 67314"
          ></iframe>
        </section>
      </main>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
<main id="main-content">
    <section class="bg-primary-600 py-16 lg:py-24 dark:bg-primary-900">
      <div class="container mx-auto px-4 text-center lg:px-8">
        <h1 class="text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
          Mari Berbagi
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-100">
          Mari Bersama Membangun Kebaikan. Setiap rezeki yang kamu salurkan akan menjadi amal jariyah yang terus mengalir dan mendukung syiar Islam di lingkungan kampus.
        </p>
        <nav
          class="mt-6 flex items-center justify-center gap-2 text-sm text-primary-200"
          aria-label="Breadcrumb"
        >
          <a href="/" class="transition-colors hover:text-white">
            Beranda
          </a>
          <span>/</span>
          <span class="text-white">Donasi</span>
        </nav>
      </div>
    </section>

    <section class="py-16 lg:py-24 dark:bg-gray-950">
      <div class="container mx-auto px-4 lg:px-8">
        <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-16">
          
          <div class="order-2 flex flex-col justify-center lg:order-1">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white sm:text-3xl">
              Salurkan Donasi Terbaik Anda
            </h2>
            <p class="mt-4 text-gray-600 dark:text-gray-400">
              Pilih salah satu metode pembayaran di bawah ini untuk menyalurkan donasi operasional dakwah dan sosial RISPOL.
            </p>

            <div class="mt-8 space-y-4">
              <div class="flex items-center justify-between rounded-xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-gray-900">
                <div class="flex items-center gap-4">
                  <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-blue-50 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                  </div>
                  <div>
                    <div class="text-sm font-medium text-gray-500 dark:text-gray-400">DANA</div>
                    <div class="text-lg font-bold text-gray-900 dark:text-white">0856 5588 1695</div>
                    <div class="text-sm font-medium text-gray-600 dark:text-gray-400">a.n. Airin</div>
                  </div>
                </div>
              </div>

              <div class="flex items-center justify-between rounded-xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-gray-900">
                <div class="flex items-center gap-4">
                  <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-emerald-50 text-emerald-600 dark:bg-emerald-900/30 dark:text-emerald-400">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                  </div>
                  <div>
                    <div class="text-sm font-medium text-gray-500 dark:text-gray-400">Bank BSI (Contoh)</div>
                    <div class="text-lg font-bold text-gray-900 dark:text-white">7123 4567 89</div>
                    <div class="text-sm font-medium text-gray-600 dark:text-gray-400">a.n. RISPOL Lumajang</div>
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-8 rounded-xl bg-primary-50 p-6 dark:bg-primary-900">
              <h3 class="text-sm font-bold text-primary-900 dark:text-primary-100">Penting:</h3>
              <p class="mt-2 text-sm text-primary-800 dark:text-primary-200">
                Setelah melakukan transfer, mohon konfirmasi agar donasi dapat dicatat dengan baik.
              </p>
              
              <a
                href="https://wa.me/6285655881695?text=Assalamu'alaikum%20Airin,%20saya%20ingin%20mengkonfirmasi%20donasi%20sebesar%20Rp%20.......%20melalui%20(DANA/BSI).%20Berikut%20bukti%20transfernya."
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 flex w-full items-center justify-center gap-2 rounded-lg bg-primary-600 px-6 py-3.5 text-base font-semibold text-white shadow-lg transition-all hover:bg-primary-700"
              >
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
                Konfirmasi via WhatsApp
              </a>
            </div>
          </div>

         <div class="order-1 lg:order-2 h-full flex items-center justify-center">
            <div class="relative w-full rounded-2xl bg-gray-50 dark:bg-gray-900 shadow-xl overflow-hidden flex items-center justify-center p-4">
               <img
                src="/src/assets/img/donasi1.jpeg"
                alt="Poster Kampanye Gema Shodaqoh Qurban"
                class="h-auto max-h-[550px] w-full object-contain"
                loading="lazy"
              />
            </div>
          </div>

        </div>
      </div>
    </section>
  </main>
</BaseLayout>
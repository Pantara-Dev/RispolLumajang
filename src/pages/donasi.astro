---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <main id="main-content">
    <!-- Judul & Deskripsi singkat -->
    <section class="bg-primary-600 py-16 lg:py-24 dark:bg-primary-900">
      <div class="container mx-auto px-4 text-center lg:px-8">
        <h1 class="text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
          Mari Berbagi
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-100">
          Mari Bersama Membangun Kebaikan. Setiap rezeki yang kamu salurkan akan menjadi amal jariyah yang terus mengalir dan mendukung syiar Islam di lingkungan kampus.
        </p>
        <nav
          class="mt-6 flex items-center justify-center gap-2 text-sm text-primary-200"
          aria-label="Breadcrumb"
        >
          <a href="../index.html" class="transition-colors hover:text-white">
            Beranda
          </a>
          <span>/</span>
          <span class="text-white">Donasi</span>
        </nav>
      </div>
    </section>

    <!-- Menu Donasi (tujuan, nama lengkap, email/nomor telepon, dan opsi pembayaran) -->
    <div class="rounded-2xl bg-white p-8 shadow-sm dark:bg-gray-800">
      <form class="space-y-6">
        <div>
          <label
            class="mb-2 block text-sm font-medium text-gray-900 dark:text-white"
            >Tujuan Donasi / Kebutuhan</label
          >
          <select
            class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-gray-900 focus:border-primary-500 focus:outline-none dark:border-gray-600 dark:bg-gray-700 dark:text-white"
          >
            <option value="operasional">Operasional Dakwah RISPOL</option>
            <option value="kajian">Fasilitas Kajian Rutin</option>
            <option value="sosial">Bakti Sosial & Santunan</option>
          </select>
        </div>

        <div>
          <label
            class="mb-2 block text-sm font-medium text-gray-900 dark:text-white"
            >Nominal Donasi (Rp)</label
          >
          <input
            type="number"
            placeholder="Contoh: 50000"
            class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-gray-900 focus:border-primary-500 focus:outline-none dark:border-gray-600 dark:bg-gray-700 dark:text-white"
            required
          />
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label
              class="mb-2 block text-sm font-medium text-gray-900 dark:text-white"
              >Nama Lengkap</label
            >
            <input
              type="text"
              placeholder="Hamba Allah"
              class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-gray-900 focus:border-primary-500 focus:outline-none dark:border-gray-600 dark:bg-gray-700 dark:text-white"
              required
            />
          </div>
          <div>
            <label
              class="mb-2 block text-sm font-medium text-gray-900 dark:text-white"
              >Email / No. WhatsApp</label
            >
            <input
              type="text"
              placeholder="0812xxx / email@domain.com"
              class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-gray-900 focus:border-primary-500 focus:outline-none dark:border-gray-600 dark:bg-gray-700 dark:text-white"
              required
            />
          </div>
        </div>

        <div>
          <label
            class="mb-2 block text-sm font-medium text-gray-900 dark:text-white"
            >Metode Pembayaran</label
          >
          <select
            class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-gray-900 focus:border-primary-500 focus:outline-none dark:border-gray-600 dark:bg-gray-700 dark:text-white"
          >
            <option value="bni">Transfer Bank BNI</option>
            <option value="bsi">Transfer Bank BSI</option>
            <option value="qris">QRIS</option>
            <option value="ewallet">GoPay / Dana / OVO</option>
          </select>
        </div>

        <button
          type="submit"
          class="w-full rounded-lg bg-primary-600 px-6 py-3.5 text-base font-medium text-white shadow-lg transition-all hover:bg-primary-700"
        >
          Lanjutkan Donasi
        </button>
      </form>
    </div>
  </main>
</BaseLayout>
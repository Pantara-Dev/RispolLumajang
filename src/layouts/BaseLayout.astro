---
const { title = "UKM RISPOL Lumajang" } = Astro.props;
import '../styles/global.css';
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<html lang="en">
 <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="UKM RISPOL PSDKU Lumajang - Unit Kegiatan Mahasiswa yang berdedikasi untuk mengembangkan potensi keislaman, kepemimpinan, dan sosial di lingkungan kampus."
    />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <meta property="og:image" content="og-image.html" />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Wadah aspirasi dan pengembangan potensi keislaman mahasiswa Politeknik Negeri Malang PSDKU Lumajang."
    />
    <meta property="og:site_name" content="UKM RISPOL Lumajang" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com/" />
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin />
    <!-- Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;display=swap"
      rel="stylesheet"
    />
    <!-- Dark mode script (prevent flash) -->
    <script>
      function applyTheme() {
        if (
          localStorage.theme === "dark" ||
          (!("theme" in localStorage) &&
            window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      }
      applyTheme();
      document.addEventListener("astro:after-swap", applyTheme);
    </script>
    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "UKM RISPOL PSDKU Lumajang",
        "description": "Unit Kegiatan Mahasiswa Islam di Politeknik Negeri Malang PSDKU Lumajang.",
        "url": "/",
        "telephone": "+6281459101209",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "JLT",
          "addressLocality": "Lumajang",
          "addressRegion": "Jawa Timur",
          "postalCode": "67314",
          "addressCountry": "ID"
        },
        "openingHours": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday"
            ],
            "opens": "08:00",
            "closes": "17:00"
          }
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": [
              "Saturday",
            ],
            "opens": "10:00",
            "closes": "16:00"
          }
        ],
        "sameAs": [
          "https://www.instagram.com/ukm_rispol/",
          "https://www.tiktok.com/@ukmrispol_2026"
        ]
      }
    </script> 
  </head>
  <body>
    <Header/>
    <main>
      <slot/>
    </main>
    <Footer/>

     <!-- Hide preloader -->
     <script>
      import "../script/main.js";
     </script>

    <script>
  window.addEventListener("load", function () {
    const p = document.getElementById("preloader");

    if (p !== null) {
      p.style.opacity = "0";

      setTimeout(function () {
        p.remove();
      }, 300);
    }
  });

  document.addEventListener("astro:before-swap", function (e) {
    const p = e.newDocument?.getElementById("preloader");

    if (p !== null && p !== undefined) {
      p.remove();
    }
  });
</script>
   
  </body>
</html>
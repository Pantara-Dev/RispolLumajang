---
const { title = "RISPOL Lumajang" } = Astro.props;
import '../styles/global.css';
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

---

<html lang="en">
 <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Professional cleaning services for homes and offices. Insured, bonded, and eco-friendly."
    />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <meta property="og:image" content="og-image.html" />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Home | SparkleClean Pro" />
    <meta
      property="og:description"
      content="Professional cleaning services for homes and offices. Insured, bonded, and eco-friendly."
    />
    <meta property="og:site_name" content="SparkleClean Pro" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Home | SparkleClean Pro" />
    <meta
      name="twitter:description"
      content="Professional cleaning services for homes and offices. Insured, bonded, and eco-friendly."
    />
    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com/" />
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin />
    <!-- Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;display=swap"
      rel="stylesheet"
    />
    <!-- Dark mode script (prevent flash) -->
    <script>
      function applyTheme() {
        if (
          localStorage.theme === "dark" ||
          (!("theme" in localStorage) &&
            window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      }
      applyTheme();
      document.addEventListener("astro:after-swap", applyTheme);
    </script>
    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "HomeAndConstructionBusiness",
        "name": "SparkleClean Pro",
        "description": "Professional residential and commercial cleaning services. Insured, bonded, and eco-friendly.",
        "url": "/",
        "telephone": "(555) 867-5309",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "456 Clean Street",
          "addressLocality": "Portland",
          "addressRegion": "OR",
          "postalCode": "97201",
          "addressCountry": "US"
        },
        "openingHours": [
          "Mo-Fr 07:00-19:00",
          "Sa 08:00-17:00",
          "Su 10:00-16:00"
        ]
      }
    </script> 
  </head>
  <body>
    <Header/>
    <main>
      <slot/>
    </main>
    <Footer/>


     <!-- Hide preloader -->

     <script>
      import "../script/main.js";
     </script>

    <script>
  window.addEventListener("load", function () {
    const p = document.getElementById("preloader");

    if (p !== null) {
      p.style.opacity = "0";

      setTimeout(function () {
        p.remove();
      }, 300);
    }
  });

  document.addEventListener("astro:before-swap", function (e) {
    const p = e.newDocument?.getElementById("preloader");

    if (p !== null && p !== undefined) {
      p.remove();
    }
  });
</script>
   
  </body>
</html>